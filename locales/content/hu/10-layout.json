  "web.meta.were_making_onetime_secret_available_in_multiple": {
    "text": "Az {onetime-secret}-et több nyelven is elérhetővé tesszük. Mivel ez egy új funkció, fordítási hibákba vagy furcsa megfogalmazásokba ütközhet. Visszajelzése segít fejlődnünk - ha bármilyen problémát észlel, kérjük, {send-feedback}",
    "source_hash": "3b482d7f"
  },
  "web.meta.translations_are_new_spotted_an_error": {
    "text": "A fordítások újak. Hibát észlelt? {send-feedback}",
    "source_hash": "31eca08d"
  },
  "web.meta.we_recently_added_translations": {
    "text": "Nemrég adtuk hozzá a fordításokat. Hibát találtál? {send-feedback}",
    "source_hash": "6e2455c1"
  },
  "web.meta.privacy_and_security_should_be_accessible": {
    "text": "Az adatvédelemnek és biztonságnak mindenkisz számára elérhetőnek kell lennie, nyelvtől függetlenül. Fordításokat adunk hozzá, hogy segítsük felhasználóinkat és üzeneteik címzettjeit jobban megérteni, hogyan használják biztonságosan az üzeneteket és hivatkozásokat. Mivel ez egy új funkció, néhány fordítási hibába vagy nem egyértelmű utasításba ütközhet. Hogy segítsen nekünk javítani fordításaink egyértelműségét és pontosságát, különösen a kritikus biztonsági tartalmak esetében, kérjük, {send-feedback}, ha bármilyen problémát észlel",
    "source_hash": "1b8bb38f"
  },
  "web.help.learn_more": {
    "text": "Tudj meg többet",
    "source_hash": "1445799c"
  },
  "web.help.secret_view_faq.what_am_i_looking_at.title": {
    "text": "Mit látok?",
    "source_hash": "b9766df3"
  },
  "web.help.secret_view_faq.what_am_i_looking_at.description": {
    "text": "Egy biztonságos üzenetet tekintesz meg, amelyet az Onetime Secret segítségével osztottak meg veled. Ez a tartalom csak egyszer jelenik meg, majd véglegesen törlődik a szervereinkről.",
    "source_hash": "e0f1a10c"
  },
  "web.help.secret_view_faq.can_i_view_again.title": {
    "text": "Megnézhetem ezt a titkot később újra?",
    "source_hash": "c8c2c9da"
  },
  "web.help.secret_view_faq.can_i_view_again.description": {
    "text": "Nem. Biztonsági okokból ez a titok csak egyszer tekinthető meg. Az oldal bezárása után a tartalom véglegesen törlődik, és senki sem tudja helyreállítani, beleértve minket sem.",
    "source_hash": "4bf980a4"
  },
  "web.help.secret_view_faq.how_to_copy.title": {
    "text": "Hogyan menthetem el ezt az információt?",
    "source_hash": "90deddbb"
  },
  "web.help.secret_view_faq.how_to_copy.description": {
    "text": "Használd a \"Másolás vágólapra\" gombot a teljes titok másolásához. Hosszabb titkok esetén győződj meg róla, hogy a teljes tartalmat kimásoltad, mielőtt elhagyod ezt az oldalt.",
    "source_hash": "440aa828"
  },
  "web.help.secret_view_faq.is_my_viewing_tracked.title": {
    "text": "Nyomon követhető, hogy megnéztem ezt a titkot?",
    "source_hash": "90145e28"
  },
  "web.help.secret_view_faq.is_my_viewing_tracked.description": {
    "text": "A küldő értesítést kap arról, hogy a titkát megtekintették, de nem követjük nyomon, hogy ki és honnan nézte meg. A magánszférádat védjük.",
    "source_hash": "70737473"
  },
  "web.help.secret_view_faq.one_time_warning": {
    "text": "Ha elhagyod vagy frissíted ezt az oldalt, ez a titok véglegesen törlődik, és senki sem tudja helyreállítani.",
    "source_hash": "47feab6e"
  },
