# Auto-generated files
src/auto-imports.d.ts
src/.eslintrc-auto-import.json
*.pyc

# Generated files (locales, types, OpenAPI, docs) - produced by sync/type-gen/openapi/typedoc scripts
generated/locales/*.json
generated/types/*.d.ts
generated/openapi/*.json
generated/outputs
generated/docs/
# Derived i18n governance cache — .resolved/ JSON + for-translators guides
# (translation-rules ADR-005): never committed; regenerated on demand at the pin.
generated/i18n/
# On-demand authority checkout used by locales/scripts/derive-governance.sh
# (read-only translation-rules clone at the canonical pin); never committed.
/.translation-rules/

scripts/api-validation/captures
scripts/api-validation/diffs

# Environment files
.env*
.test-mode
!.env.example
!.env.reference
!.env.test.example


# Playwright paths
test-results/
playwright-report/
blob-report/
playwright/.cache/
# Saved authenticated session (e2e/global.setup.ts) - never commit
e2e/.auth/
e2e/visual/.artifacts/
# Backstop against committing macOS baselines (Linux baselines only)
e2e/visual/**/*-darwin.png
*.egg-info/

# Local direnv overlay markers in test lanes (tests/lanes/README.md)
tests/lanes/**/.overlays

# Test lanes are the exception to the env-file ignore rules above:
# committed on purpose, dummy values only (tests/lanes/README.md)
!tests/lanes/**/.envrc
!tests/lanes/base.env
!tests/lanes/overlays/*.env

# Per-run i18n PR-review artifacts (pr-per-locale.sh). Not committed here; may
# move to the translation-rules repo as an audit trail. See locales/BATCH_OPERATIONS.md.
locales/reviews/
