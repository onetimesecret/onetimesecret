# Ignore personal editor settings but SHARE the project-level config files.
# Must ignore dir CONTENTS (.vscode/*), not the dir (.vscode/) — git cannot
# re-include a file whose parent directory is itself excluded.
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
.cache/
.temp/
.zed/*
!.zed/settings.json
.appendonlydir/
.bundle/
.rspec
.rspec_status
appendonlydir/
data
exports
results
doc/
node_modules/
vendor/
log/
tmp/
coverage/
dist/
public/web/dist/
public/doc
# Runtime brand-asset packs (#3739): public/branding/<pack>/ is generator
# output (pnpm run gen:favicons:<pack>), never committed — the repo stays
# brand-neutral. Ignore the CONTENTS (not the dir) so the README stays tracked;
# git cannot re-include a file whose parent directory is itself excluded (see
# .vscode note above).
#
# The `default` pack (#3774) is the ONE tracked exception: it holds the neutral
# asset set + a value-free brand.yaml and is the pack every unset BRAND_PACK
# resolves to. Re-include the directory so git descends into it (its files are
# not matched by the single-level `*` above, so they track normally).
public/branding/*
!public/branding/README.md
!public/branding/default/
!tests/data

