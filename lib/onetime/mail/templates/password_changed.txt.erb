<%
  _changed_time = (Time.parse(changed_at.to_s) rescue nil)
  _changed_date = _changed_time ? _changed_time.strftime('%B %d, %Y') : changed_at.to_s
  _changed_clock = _changed_time ? _changed_time.strftime('%H:%M UTC') : ''
-%>
<%= t('email.password_changed.title') %>

<%= t('email.password_changed.body', product_name: product_name, date: _changed_date, time: _changed_clock) %>

<%= t('email.password_changed.security_notice') %>

<%= baseuri %><%= security_settings_path %>

<%= signature_name || t('email.password_changed.signature') %>
