#!/usr/bin/env bash

# bin/dev - Development Process Runner (overmind or hivemind)
#
# USAGE:
#   $ bin/dev                       # Start with Procfile.dev
#   $ bin/dev --volatile            # Start with Procfile.volatile (no persistent data)
#   $ bin/dev --port=7144           # Override port (also: -p 7144 or PORT=7144 bin/dev)
#
# WINDOW MODES:
#   Main Window (bin/dev): Pure log stream. Bird's-eye view of all processes.
#                          Non-interactive (Ctrl+C kills everything).
#   Connect Mode:          Interactive TTY. Run in a separate terminal tab to
#                          access debuggers (pry/debugger) or restart services.
#
# -----------------------------------------------------------------------------
# CONTROL COMMANDS (New Terminal Tab)
# -----------------------------------------------------------------------------
#   $ overmind connect <name>       # Open interactive TTY (backend|frontend|worker)
#   $ overmind restart <name>       # Restart a specific process
#   $ overmind stop <name>          # Kill a specific process
#
# -----------------------------------------------------------------------------
# CONNECT MODE SHORTCUTS (Inside 'overmind connect')
# -----------------------------------------------------------------------------
#   Ctrl+b, d                       # Detach (Return to shell, process keeps running)
#   r                               # Restart the process you are connected to
#   q                               # Quit connection (Process keeps running)
#
#   Usage: Essential for 'binding.pry', 'debugger', or surgical restarts.
# -----------------------------------------------------------------------------

if command -v overmind >/dev/null 2>&1; then
  RUNNER="overmind"
elif command -v hivemind >/dev/null 2>&1; then
  RUNNER="hivemind"
else
  echo "Error: Neither overmind nor hivemind found."
  echo "  Install overmind: https://github.com/DarthSim/overmind"
  echo "  Install hivemind: https://github.com/DarthSim/hivemind"
  exit 1
fi

# Parse arguments
PROCFILE="Procfile.dev"
PORT_OVERRIDE=""
ARGS=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --volatile)
      echo "Starting in volatile mode (no persistent data)..."
      PROCFILE="Procfile.volatile"
      shift
      ;;
    --port=*|-p=*)
      PORT_OVERRIDE="${1#*=}"
      shift
      ;;
    --port|-p)
      if [[ -z "$2" || "$2" == -* ]]; then
        echo "Error: '$1' requires a port value." >&2
        exit 1
      fi
      PORT_OVERRIDE="$2"
      shift 2
      ;;
    *)
      ARGS+=("$1")
      shift
      ;;
  esac
done

# Verify direnv has loaded the environment. Without this, overmind launches
# with whatever env the parent shell happens to have — potentially pointing
# at the wrong database.
if [[ -z "${OTS_ENV_LOADED:-}" ]]; then
  echo "Error: OTS_ENV_LOADED is not set — direnv has not loaded the environment."
  echo "  Run: direnv allow .    (or re-run install-dev.sh)"
  exit 1
fi

# Ensure PORT is a valid integer (Overmind fails if empty or invalid)
# --port flag takes precedence over PORT env var, then falls back to 7143
PORT="${PORT_OVERRIDE:-${PORT:-7143}}"

if [[ "$RUNNER" == "overmind" ]]; then
  exec env PORT="$PORT" overmind start -f "$PROCFILE" "${ARGS[@]}"
else
  exec env PORT="$PORT" hivemind "$PROCFILE" "${ARGS[@]}"
fi
