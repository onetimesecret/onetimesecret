#!/usr/bin/env bash
#
# bin/frontend - Start just the frontend service via Overmind.
# For all services, use: bin/dev

if ! command -v overmind >/dev/null 2>&1; then
  echo "Error: Overmind not found. Install with: brew install overmind"
  exit 1
fi

if [ -f .env.sh ]; then
  set -a
  . .env.sh
  set +a
fi

exec overmind start -f Procfile.dev -l frontend
