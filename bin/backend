#!/usr/bin/env bash
#
# bin/backend - Start just the backend service via Overmind.
# For all services, use: bin/dev

if ! command -v overmind >/dev/null 2>&1; then
  echo "Error: Overmind not found. Install with: brew install overmind"
  exit 1
fi

PORT="${PORT:-7143}"

exec env PORT="$PORT" overmind start -f Procfile.dev -l backend
