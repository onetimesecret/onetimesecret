#!/usr/bin/env bash

# bin/visual - Visual regression suite runner (Playwright screenshots)
#
# USAGE:
#   $ bin/visual               # seed fixtures, boot server, compare against baselines
#   $ bin/visual --update      # same, but rewrite baselines (--update-snapshots)
#   $ bin/visual --seed-only   # seed fixtures only (no server boot, no screenshots)
#
# WHAT IT DOES:
#   1. Boots `bin/ots server` (RACK_ENV=production) on :7143 with the visual
#      lane's env. DOMAINS_ENABLED=true is non-negotiable: it defaults false,
#      and without it every Host header classifies :canonical — the branded
#      fixtures would silently screenshot the default UI and the first
#      baseline run would enshrine that false negative forever.
#   2. Seeds brand/secret fixtures via `rake qa:visual:seed` (armed with
#      QA_VISUAL_SEED=1), which writes the generated IDs to
#      e2e/visual/.artifacts/seed-manifest.json for the specs to read.
#   3. Runs the visual Playwright projects inside the pinned Linux container
#      (podman) so baselines are always *-linux.png. Never run this lane bare
#      on macOS: darwin font rendering produces phantom diffs.
#
# NETWORKING (podman machine on macOS):
#   Chromium inside the container maps *.example.com / *.example.org to
#   VISUAL_RESOLVER_TARGET via --host-resolver-rules (see the visual projects
#   in e2e/playwright.config.ts). This script sets that target to
#   host.containers.internal: gvproxy's DNS resolves it to 192.168.127.254
#   and NATs that IP to the mac host's 127.0.0.1 (gvisor-tap-vsock
#   cmd/gvproxy/config.yaml: `nat: 192.168.127.254: 127.0.0.1`), so puma's
#   default 127.0.0.1 bind is reachable without opening the port up.
#   host.docker.internal is served by the same gvproxy DNS zone — use it as
#   the fallback (VISUAL_RESOLVER_TARGET=host.docker.internal bin/visual) if
#   an older gvproxy lacks the containers.internal zone.
#
# See docs/specs/qa/visual-regressions/qa-visual-regressions-approach.md.

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$REPO_ROOT"

# Pinned Playwright container image. The tag MUST match the @playwright/test
# version in package.json exactly (browser build numbers are coupled to the
# npm package) — bump both together or the container's browsers won't match
# what the host-mounted node_modules expects.
PLAYWRIGHT_IMAGE="mcr.microsoft.com/playwright:v1.58.2-noble"

PORT="${PORT:-7143}"
CANONICAL_HOST="canonical.example.org"
DIST_DIR="$REPO_ROOT/public/web/dist"
SERVER_LOG="$REPO_ROOT/tmp/visual-server.log"
READY_TIMEOUT=60

# Env shared by the server boot and the seed task. They MUST agree: the seed
# writes to the datastore the server reads, and both sides have to classify
# the fixture hosts identically (DOMAINS_ENABLED + DEFAULT_DOMAIN).
# SSL=false pins http:// links/cookies even if the ambient shell exports SSL.
# LANG guards the scripted Ruby boot against "invalid byte sequence in
# US-ASCII" when launched from a non-UTF-8 environment.
VISUAL_ENV=(
  RACK_ENV=production
  "LANG=${LANG:-en_US.UTF-8}"
  SSL=false
  DOMAINS_ENABLED=true
  "DEFAULT_DOMAIN=$CANONICAL_HOST"
  # site.host renders into the page (e.g. the homepage "Creating links for"
  # pill). Unpinned, the ambient dev HOST leaks into every baseline and no
  # other machine can reproduce them.
  "HOST=$CANONICAL_HOST:$PORT"
  INCOMING_ENABLED=true
  "INCOMING_RECIPIENT_1=qa-visual-recipient@example.com,QA Recipient"
  # Every config surface that RENDERS must be pinned, or ambient dev env
  # leaks into baselines no other machine (or CI) can reproduce. Values are
  # the config defaults: regions off (no footer region pill), billing off,
  # signup/signin on (header links).
  REGIONS_ENABLED=false
  JURISDICTION=
  JURISDICTIONS=
  BILLING_ENABLED=false
  AUTH_SIGNUP=true
  AUTH_SIGNIN=true
  # Pinned for environment determinism (and prod parity — prod runs full).
  # The noauth visual pages currently render identically across auth modes,
  # but an ambient mode flip must never become a screenshot variable. The DB
  # engine behind full mode is free to vary: PG when AUTH_DATABASE_URL is
  # set (dev), boot-migrated sqlite when unset (CI) — engine never renders.
  AUTHENTICATION_MODE=full
)
# ACCOUNT_ID_SECRET is appended after the environment guards below — it may be
# derived from SECRET, which is only validated there.

usage() {
  echo "Usage: bin/visual [--update | --seed-only]"
  echo "  (no flag)     seed fixtures, boot server, compare against committed baselines"
  echo "  --update      same, but rewrite baselines (passes --update-snapshots)"
  echo "  --seed-only   run the fixture seed task only; no server, no screenshots"
}

# --- Argument parsing (fail fast on anything unknown) ------------------------
MODE="run"
while [[ $# -gt 0 ]]; do
  case "$1" in
    --update)
      MODE="update"
      shift
      ;;
    --seed-only)
      MODE="seed-only"
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "Error: unknown argument '$1'" >&2
      usage >&2
      exit 1
      ;;
  esac
done

# --- Dependency checks --------------------------------------------------------
require_cmd() {
  if ! command -v "$1" >/dev/null 2>&1; then
    echo "Error: '$1' not found. $2" >&2
    exit 1
  fi
}

# Container runtime: podman (macOS dev) or docker (CI runners). Ambient
# CONTAINER_RUNTIME wins; otherwise prefer podman (this project's default —
# see CLAUDE.md/docs) and fall back to docker.
if [[ -z "${CONTAINER_RUNTIME:-}" ]]; then
  if command -v podman >/dev/null 2>&1; then
    CONTAINER_RUNTIME=podman
  elif command -v docker >/dev/null 2>&1; then
    CONTAINER_RUNTIME=docker
  else
    echo "Error: neither podman nor docker found." >&2
    echo "  Install: brew install podman && podman machine init && podman machine start" >&2
    exit 1
  fi
fi
require_cmd "$CONTAINER_RUNTIME" "Set CONTAINER_RUNTIME to an installed runtime (podman or docker)."
require_cmd pnpm   "Install: brew install pnpm (needed for 'pnpm build' and report viewing)"
require_cmd bundle "Install Ruby deps: gem install bundler && bundle install"
require_cmd curl   "Needed for the server readiness probe."

# --- Environment guards (same convention as bin/dev) --------------------------
if [[ -z "${OTS_ENV_LOADED:-}" ]]; then
  echo "Error: OTS_ENV_LOADED is not set — direnv has not loaded the environment." >&2
  echo "  Run: direnv allow .    (or re-run bin/setup)" >&2
  exit 1
fi

# RACK_ENV=production boot requires site.secret; both the server and the seed
# task (encrypted fields, objid minting) die without it. Fail here, loudly,
# instead of half-way through a boot.
if [[ -z "${SECRET:-}" ]]; then
  echo "Error: SECRET is not set — production-mode boot requires it (etc/defaults/config.defaults.yaml)." >&2
  echo "  direnv normally provides it; run: direnv allow ." >&2
  exit 1
fi

# Full auth mode + RACK_ENV=production additionally requires ACCOUNT_ID_SECRET
# (Rodauth account-id obfuscation; the registry aborts boot without it). Dev
# direnv typically doesn't export it because development-mode boots don't need
# it. The visual pages are all noauth — the value only has to exist for Rodauth
# to mount — so derive a deterministic ephemeral one from SECRET when absent.
# An ambient ACCOUNT_ID_SECRET always wins.
if [[ -z "${ACCOUNT_ID_SECRET:-}" ]]; then
  ACCOUNT_ID_SECRET="$(printf 'visual:%s' "$SECRET" | shasum -a 256 | cut -d' ' -f1)"
fi
VISUAL_ENV+=("ACCOUNT_ID_SECRET=$ACCOUNT_ID_SECRET")

# Same story for AUTH_SECRET (Rodauth hmac_secret, apps/web/auth/config/
# base.rb): required for full-mode production boot, normally direnv-provided,
# never used by the noauth visual pages. Derive when absent.
if [[ -z "${AUTH_SECRET:-}" ]]; then
  AUTH_SECRET="$(printf 'visual-auth:%s' "$SECRET" | shasum -a 256 | cut -d' ' -f1)"
fi
VISUAL_ENV+=("AUTH_SECRET=$AUTH_SECRET")

# tmp/ holds the server log and the ephemeral authdb below. Fresh checkouts
# (CI) don't have it — and without it the boot's log redirect fails silently.
mkdir -p "$REPO_ROOT/tmp"

# Full auth mode needs an authdb. An ambient AUTH_DATABASE_URL (dev PG) wins;
# otherwise use an ephemeral sqlite under tmp/, recreated every run. Two traps
# this dodges: the default sqlite://data/auth.db lives in data/, which is an
# untracked dev symlink (absent on fresh checkouts/CI); and a stale sqlite
# from an older branch can be AHEAD of this code's schema, which fails boot
# with a down-migration error. The visual pages are all noauth — the authdb
# only has to exist and migrate for Rodauth to mount.
if [[ -z "${AUTH_DATABASE_URL:-}" ]]; then
  rm -f "$REPO_ROOT/tmp/visual-auth.db"
  VISUAL_ENV+=("AUTH_DATABASE_URL=sqlite://tmp/visual-auth.db")
fi

# --- Asset staleness (screenshots of stale assets are worse than no run) ------
if [[ "$MODE" != "seed-only" ]]; then
  if [[ ! -d "$DIST_DIR" ]]; then
    echo "Error: $DIST_DIR is missing — the production server serves built assets." >&2
    echo "  Run: pnpm build" >&2
    echo "  (Not run automatically: an unnoticed auto-build could mask what you meant to compare.)" >&2
    exit 1
  fi
  dist_mtime="$(stat -f '%Sm' "$DIST_DIR" 2>/dev/null || stat -c '%y' "$DIST_DIR" 2>/dev/null || echo unknown)"
  echo "Caution: screenshots use built assets from public/web/dist (last built: $dist_mtime)."
  echo "         If frontend code changed since then, run 'pnpm build' first."
fi

# --- Pin the rendered commit hash -----------------------------------------------
# The footer version string is "v<pkg> (<hash>)" (lib/onetime/version.rb,
# reading .commit_hash.txt in preference to git). The hash element is masked
# in the screenshots, but its RENDERED WIDTH varies per hash (proportional
# font), shifting the adjacent "Powered by" text a few px — enough to fail
# the comparison on every commit. Pin the hash for the run; restore after.
COMMIT_HASH_FILE="$REPO_ROOT/.commit_hash.txt"
COMMIT_HASH_BAK=""
if [[ -f "$COMMIT_HASH_FILE" ]]; then
  COMMIT_HASH_BAK="$(cat "$COMMIT_HASH_FILE")"
fi
printf '0000000\n' >"$COMMIT_HASH_FILE"

# --- Server lifecycle ----------------------------------------------------------
SERVER_PID=""
cleanup() {
  if [[ -n "$COMMIT_HASH_BAK" ]]; then
    printf '%s\n' "$COMMIT_HASH_BAK" >"$COMMIT_HASH_FILE"
  else
    rm -f "$COMMIT_HASH_FILE"
  fi
  if [[ -n "$SERVER_PID" ]] && kill -0 "$SERVER_PID" 2>/dev/null; then
    kill "$SERVER_PID" 2>/dev/null || true
    wait "$SERVER_PID" 2>/dev/null || true
  fi
}
trap cleanup EXIT

if [[ "$MODE" != "seed-only" ]]; then
  # Port guard: never reuse an unknown server. One booted without
  # DOMAINS_ENABLED=true would classify every host :canonical and silently
  # produce canonical-only screenshots — the exact false negative this suite
  # exists to prevent.
  if lsof -nP -iTCP:"$PORT" -sTCP:LISTEN >/dev/null 2>&1; then
    echo "Error: something is already listening on :$PORT — refusing to reuse it." >&2
    echo "  A server booted with the wrong env (e.g. DOMAINS_ENABLED unset) would" >&2
    echo "  silently render canonical branding for every fixture. Stop it first:" >&2
    lsof -nP -iTCP:"$PORT" -sTCP:LISTEN >&2
    exit 1
  fi

  echo "Booting bin/ots server on :$PORT (log: $SERVER_LOG)..."
  env "${VISUAL_ENV[@]}" bin/ots server --port="$PORT" >"$SERVER_LOG" 2>&1 &
  SERVER_PID=$!

  # Readiness: the page must contain the SPA bootstrap marker (same probe the
  # e2e workflow uses — .github/workflows/e2e.yml greps __BOOTSTRAP_ME__).
  printf 'Waiting for readiness (SPA bootstrap marker)'
  deadline=$((SECONDS + READY_TIMEOUT))
  until curl -fsS "http://127.0.0.1:$PORT/" 2>/dev/null | grep -q '__BOOTSTRAP_ME__'; do
    if ! kill -0 "$SERVER_PID" 2>/dev/null; then
      printf '\n'
      echo "Error: server exited during boot. Last 40 log lines ($SERVER_LOG):" >&2
      tail -n 40 "$SERVER_LOG" >&2
      exit 1
    fi
    if ((SECONDS >= deadline)); then
      printf '\n'
      echo "Error: server not ready after ${READY_TIMEOUT}s. Last 40 log lines ($SERVER_LOG):" >&2
      tail -n 40 "$SERVER_LOG" >&2
      exit 1
    fi
    printf '.'
    sleep 1
  done
  printf ' ready.\n'
fi

# --- Seed fixtures ---------------------------------------------------------------
echo "Seeding visual fixtures (rake qa:visual:seed)..."
env "${VISUAL_ENV[@]}" QA_VISUAL_SEED=1 bundle exec rake qa:visual:seed

if [[ "$MODE" == "seed-only" ]]; then
  echo "Seed complete. Manifest: e2e/visual/.artifacts/seed-manifest.json"
  exit 0
fi

# --- Run Playwright in the pinned Linux container --------------------------------
UPDATE_ARG=""
if [[ "$MODE" == "update" ]]; then
  UPDATE_ARG="--update-snapshots"
fi

# Networking differs by runtime:
# - podman (macOS): gvproxy NATs host.containers.internal to the mac host's
#   127.0.0.1 (see header comment), so the default bridge network works.
# - docker (linux CI): host.docker.internal:host-gateway maps to the bridge
#   gateway, which can NOT reach puma's 127.0.0.1 bind — so share the host's
#   network namespace instead and resolve the fixture hosts straight to
#   127.0.0.1.
NETWORK_ARGS=()
if [[ "$CONTAINER_RUNTIME" == "docker" && "$(uname -s)" == "Linux" ]]; then
  NETWORK_ARGS=(--network host)
  RESOLVER_DEFAULT="127.0.0.1"
else
  RESOLVER_DEFAULT="host.containers.internal"
fi

echo "Running Playwright in $PLAYWRIGHT_IMAGE ($CONTAINER_RUNTIME)..."
# --ipc=host: Chromium exhausts /dev/shm without it (playwright.dev/docs/docker).
# CI is deliberately NOT passed in: containers don't inherit host env, so the
# config's CI-only branches (retries, blob reporter, workers=1) stay off and
# the run behaves identically on a dev machine and a CI runner.
# node_modules is the host's — fine because @playwright/test and playwright
# are pure JS and the browsers come from the image at /ms-playwright.
"$CONTAINER_RUNTIME" run --rm \
  --ipc=host \
  ${NETWORK_ARGS[@]+"${NETWORK_ARGS[@]}"} \
  -v "$REPO_ROOT":/work \
  -w /work \
  -e "PLAYWRIGHT_BASE_URL=http://$CANONICAL_HOST:$PORT" \
  -e "VISUAL_RESOLVER_TARGET=${VISUAL_RESOLVER_TARGET:-$RESOLVER_DEFAULT}" \
  "$PLAYWRIGHT_IMAGE" \
  npx playwright test \
    --config=e2e/playwright.config.ts \
    --project=visual-desktop \
    --project=visual-mobile \
    ${UPDATE_ARG:+"$UPDATE_ARG"}

echo
echo "HTML report: e2e/playwright-report/  (view: pnpm exec playwright show-report e2e/playwright-report)"
if [[ "$MODE" == "update" ]]; then
  echo "Baselines updated. Check 'git status': ONLY *-linux.png files should appear."
  echo "Any *-darwin.png means a bare-metal run leaked in — do not commit those."
fi
