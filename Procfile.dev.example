# Procfile.dev.example
#
# Copy to Procfile.dev (or run install-dev.sh to symlink from OTS_DEV_CONFIG).
#
# Usage:
#   bin/dev           # all services
#   bin/backend       # backend only
#   bin/frontend      # frontend only

# Uncomment to run an ephemeral local valkey. Port must match REDIS_URL in .env
# (default 127.0.0.1:6379).
#valkey: valkey-server --port 6379 --save "" --appendonly no

# Requires etc/puma.rb (created by install-dev.sh).
backend: bundle exec puma -C etc/puma.rb

frontend: pnpm run dev

#worker: bin/worker
