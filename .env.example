# Onetime Secret - Quick Start Configuration
#
# For bare-metal / tarball installs:
#   1. Run ./install.sh          (copies this file to .env and generates secrets)
#   2. Source environment:        source .env.sh
#   3. Start the app:            bundle exec puma -C etc/puma.rb
#
# For Docker:
#   1. docker compose up         (compose files set their own env overrides)
#
# See the YAML configs in etc/defaults for complete reference.

# ─── Root Secret ────────────────────────────────────────────
# The single root secret. All other cryptographic material is
# derived from this via HKDF (RFC 5869). Back this up.
# Generated automatically by `./install.sh init`.
SECRET=

# ─── Connections ────────────────────────────────────────────
# Default: local/bare-metal. Docker Compose overrides this
# via environment settings in docker/compose/*.yml.
REDIS_URL='redis://127.0.0.1:6379/0'

# ─── Site Identity ──────────────────────────────────────────
# Your public hostname. Include port if non-standard.
HOST=localhost:3000
SSL=false
# Set SSL=true when behind a reverse proxy that terminates TLS.


# ─── Email Delivery ────────────────────────────────────────
# Required for account verification and secret notifications.
# Leave blank to disable outbound email.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

FROM_EMAIL=secure@example.com
FROM_NAME="Secret Links"


# ─── Incoming Secrets ────────────────────────────────────────
# A destination page where users submit secret links directly to a
# preconfigured email address. i.e. /incoming
#INCOMING_ENABLED=false

# ─── Secret Privacy ────────────────────────────────────────
# Available TTL choices (space-separated, in seconds)
# Default: 300 3600 86400 604800 (5m, 1h, 1d, 7d)
#TTL_OPTIONS=

# Max TTL for anonymous users. Default: 604800 (7 days)
#PLAN_TTL_ANONYMOUS=604800

# Disable user authentication (enabled by default; set to false to disable)
#AUTH_ENABLED=false


#-----BEGIN DERIVED SECRETS (from SECRET via HKDF)-----
#SESSION_SECRET=
#IDENTIFIER_SECRET=
#-----END DERIVED SECRETS-----

#-----BEGIN INDEPENDENT SECRETS (generated, must be backed up)-----
#AUTH_SECRET=
#ARGON2_SECRET=
#-----END INDEPENDENT SECRETS-----

#-----BEGIN FEDERATION (shared across instances, auto-generated passphrase)-----
#FEDERATION_SECRET=
#-----END FEDERATION-----

#-----BEGIN OAUTH/OIDC IDP (issue #3104, required when AUTH_OAUTH_ENABLED=true)-----
# RSA 2048 PEM (single line with literal \n escapes). NEVER regenerate in prod —
# would invalidate every live ID/access token. Generate with:
#   bin/generate_oauth_keys >> .env
#OAUTH_JWT_RSA_PRIVATE_KEY=
# Issuer override. Defaults per-request from site.host; set if you need a
# stable static value (e.g., when the SP-side discovery URL must match).
#OAUTH_ISSUER=http://localhost:3000/auth
# Restrict client redirect URI schemes. Defaults to "http https" (so localhost
# callbacks work). Tighten to "https" in production.
#OAUTH_VALID_URI_SCHEMES=https

# Local IdP loopback — OTS acts as its own SSO IdP for dev/test. Setting
# the dev SP client secret enables BOTH the seeded oauth_applications row
# (with bcrypt hash of this secret) AND the SP-side OmniAuth provider that
# talks back to /auth via OIDC discovery. Route default: /auth/sso/local.
#OAUTH_SP_DEV_CLIENT_SECRET=
#OAUTH_SP_DEV_CLIENT_ID=onetimesecret-sp-dev
#OAUTH_SP_DEV_ROUTE_NAME=local
#OAUTH_SP_DEV_DISPLAY_NAME=Local IdP
#OAUTH_SP_DEV_ISSUER=http://localhost:3000/auth
#OAUTH_SP_DEV_REDIRECT_URI=http://localhost:3000/auth/sso/local/callback
#-----END OAUTH/OIDC IDP-----
