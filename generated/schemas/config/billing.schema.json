{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://onetimesecret.com/schemas/config/billing.schema.json",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$",
      "description": "Schema version identifier"
    },
    "app_identifier": {
      "type": "string",
      "minLength": 1,
      "description": "Application identifier for Stripe metadata matching"
    },
    "match_fields": {
      "default": [
        "plan_id"
      ],
      "description": "Fields used to build composite match key for Stripe product identification",
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "region": {
      "description": "Region filter for this catalog instance",
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "currency": {
      "description": "Default currency for all products and prices. Defaults to 'cad' when not set.",
      "type": "string",
      "enum": [
        "cad",
        "eur",
        "usd",
        "nzd",
        "gbp"
      ]
    },
    "entitlements": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "category": {
            "type": "string",
            "enum": [
              "core",
              "collaboration",
              "infrastructure",
              "branding",
              "advanced",
              "support"
            ]
          },
          "description": {
            "type": "string",
            "minLength": 1,
            "description": "Human-readable description of the entitlement"
          }
        },
        "required": [
          "category",
          "description"
        ],
        "additionalProperties": {}
      },
      "description": "System-wide entitlement definitions"
    },
    "plans": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "description": "Display name for the plan"
          },
          "tier": {
            "description": "Billing tier (optional for draft plans)",
            "type": "string",
            "enum": [
              "free",
              "single_account",
              "single_team",
              "multi_team"
            ]
          },
          "tenancy": {
            "description": "Tenancy type (optional for draft plans)",
            "type": "string",
            "enum": [
              "multi",
              "dedicated"
            ]
          },
          "region": {
            "description": "Region identifier for composite matching (e.g., 'EU', 'US')",
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "stripe_product_id": {
            "description": "Direct Stripe product ID binding (escape hatch for matching issues)",
            "type": "string",
            "pattern": "^prod_"
          },
          "plan_name_label": {
            "description": "i18n key for plan category label",
            "type": "string"
          },
          "display_order": {
            "description": "Sort order on plans page (higher = earlier)",
            "anyOf": [
              {
                "type": "integer",
                "minimum": 0,
                "maximum": 9007199254740991
              },
              {
                "type": "null"
              }
            ]
          },
          "show_on_plans_page": {
            "description": "Visibility on public plans page",
            "type": "boolean"
          },
          "includes_plan": {
            "description": "Plan ID this plan includes (for \"Includes everything in X\" display)",
            "type": "string"
          },
          "description": {
            "description": "Plan description for documentation",
            "type": "string",
            "minLength": 1
          },
          "legacy": {
            "description": "Marks plan as legacy/grandfathered (no longer offered)",
            "type": "boolean"
          },
          "grandfathered_until": {
            "description": "ISO date until which plan is grandfathered (YYYY-MM-DD)",
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "entitlements": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "description": "Array of entitlement IDs"
          },
          "features": {
            "description": "Array of i18n feature keys for UI display",
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "limits": {
            "type": "object",
            "properties": {
              "organizations": {
                "anyOf": [
                  {
                    "type": "integer",
                    "minimum": -1,
                    "maximum": 9007199254740991,
                    "description": "-1 = unlimited, 0+ = specific limit"
                  },
                  {
                    "type": "null",
                    "description": "To be determined"
                  }
                ],
                "description": "Maximum number of organizations"
              },
              "members_per_team": {
                "anyOf": [
                  {
                    "type": "integer",
                    "minimum": -1,
                    "maximum": 9007199254740991,
                    "description": "-1 = unlimited, 0+ = specific limit"
                  },
                  {
                    "type": "null",
                    "description": "To be determined"
                  }
                ],
                "description": "Maximum members per team"
              },
              "custom_domains": {
                "anyOf": [
                  {
                    "type": "integer",
                    "minimum": -1,
                    "maximum": 9007199254740991,
                    "description": "-1 = unlimited, 0+ = specific limit"
                  },
                  {
                    "type": "null",
                    "description": "To be determined"
                  }
                ],
                "description": "Maximum custom domains"
              },
              "secret_lifetime": {
                "anyOf": [
                  {
                    "type": "integer",
                    "minimum": -1,
                    "maximum": 9007199254740991,
                    "description": "-1 = unlimited, 0+ = specific limit"
                  },
                  {
                    "type": "null",
                    "description": "To be determined"
                  }
                ],
                "description": "Maximum secret lifetime in seconds"
              },
              "secrets_per_day": {
                "description": "Daily secret creation limit",
                "anyOf": [
                  {
                    "type": "integer",
                    "minimum": -1,
                    "maximum": 9007199254740991,
                    "description": "-1 = unlimited, 0+ = specific limit"
                  },
                  {
                    "type": "null",
                    "description": "To be determined"
                  }
                ]
              }
            },
            "required": [
              "organizations",
              "members_per_team",
              "custom_domains",
              "secret_lifetime"
            ],
            "additionalProperties": {}
          },
          "prices": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "interval": {
                  "type": "string",
                  "enum": [
                    "month",
                    "year"
                  ]
                },
                "amount": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 9007199254740991,
                  "description": "Amount in cents (e.g., 2900 = $29.00)"
                },
                "currency": {
                  "description": "Per-price currency override. Inherits from top-level currency when omitted.",
                  "type": "string",
                  "enum": [
                    "cad",
                    "eur",
                    "usd",
                    "nzd",
                    "gbp"
                  ]
                }
              },
              "required": [
                "interval",
                "amount"
              ],
              "additionalProperties": {}
            },
            "description": "Available pricing options"
          }
        },
        "required": [
          "name",
          "entitlements",
          "limits",
          "prices"
        ],
        "additionalProperties": {}
      },
      "description": "Plan definitions by plan_id (legacy plans use legacy: true flag)"
    },
    "stripe_metadata_schema": {
      "description": "Stripe product metadata schema definition",
      "type": "object",
      "properties": {
        "required": {
          "description": "Required metadata fields",
          "type": "array",
          "items": {
            "type": "object",
            "propertyNames": {
              "type": "string"
            },
            "additionalProperties": {
              "type": "string",
              "description": "Field description or example value"
            }
          }
        },
        "optional": {
          "description": "Optional metadata fields",
          "type": "array",
          "items": {
            "type": "object",
            "propertyNames": {
              "type": "string"
            },
            "additionalProperties": {
              "type": "string",
              "description": "Field description or example value"
            }
          }
        }
      },
      "additionalProperties": {}
    }
  },
  "required": [
    "schema_version",
    "app_identifier",
    "entitlements",
    "plans"
  ],
  "additionalProperties": {}
}
